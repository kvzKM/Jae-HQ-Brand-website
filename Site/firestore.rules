rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function currentUserData() {
      return get(userPath(request.auth.uid)).data;
    }

    function hasProfile() {
      return signedIn() && exists(userPath(request.auth.uid));
    }

    function isAdmin() {
      return hasProfile() && currentUserData().role == "admin";
    }

    function isPublished() {
      return resource.data.status == "published";
    }

    function validContentStatus() {
      return request.resource.data.status in ["draft", "published", "archived"];
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          "username",
          "email",
          "emoji",
          "role",
          "membership",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.role == "member"
        && request.resource.data.membership == "JAE HQ Member"
        && request.resource.data.email == request.auth.token.email;

      allow read: if isOwner(userId) || isAdmin();

      allow update: if (
          isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "username",
            "emoji",
            "updatedAt"
          ])
        )
        || isAdmin();

      allow delete: if isAdmin() && request.auth.uid != userId;
    }

    match /posts/{postId} {
      allow read: if isPublished() || isAdmin();

      allow create, update: if isAdmin()
        && validContentStatus()
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.slug is string
        && request.resource.data.slug.size() > 0;

      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isPublished() || isAdmin();

      allow create, update: if isAdmin()
        && validContentStatus()
        && request.resource.data.keys().hasAll([
          "name",
          "slug",
          "summary",
          "technologies",
          "category",
          "status",
          "featured"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.slug is string
        && request.resource.data.slug.size() > 0
        && request.resource.data.slug.size() <= 120
        && request.resource.data.summary is string
        && request.resource.data.summary.size() > 0
        && request.resource.data.summary.size() <= 500
        && request.resource.data.technologies is list
        && request.resource.data.category in [
          "web",
          "python",
          "javascript",
          "delphi",
          "other"
        ]
        && request.resource.data.featured is bool;

      allow delete: if isAdmin();
    }

    match /youtube/{entryId} {
      allow read: if isPublished() || isAdmin();
      allow create, update: if isAdmin()
        && validContentStatus()
        && request.resource.data.title is string;
      allow delete: if isAdmin();
    }

    match /books/{bookId} {
      allow read: if isPublished() || isAdmin();
      allow create, update: if isAdmin()
        && validContentStatus()
        && request.resource.data.title is string;
      allow delete: if isAdmin();
    }

    match /travel/{entryId} {
      allow read: if isPublished() || isAdmin();
      allow create, update: if isAdmin()
        && validContentStatus()
        && request.resource.data.title is string;
      allow delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;

      allow create: if hasProfile()
        && request.resource.data.keys().hasOnly([
          "postId",
          "postSlug",
          "userId",
          "username",
          "emoji",
          "text",
          "createdAt"
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.username == currentUserData().username
        && request.resource.data.emoji == currentUserData().emoji
        && request.resource.data.postId is string
        && request.resource.data.postId.size() > 0
        && request.resource.data.postSlug is string
        && request.resource.data.postSlug.size() > 0
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000
        && request.resource.data.createdAt == request.time
        && exists(/databases/$(database)/documents/posts/$(request.resource.data.postId))
        && get(/databases/$(database)/documents/posts/$(request.resource.data.postId)).data.status == "published";

      allow update: if false;

      allow delete: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
