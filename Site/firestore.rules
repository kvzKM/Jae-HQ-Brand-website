rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function currentUserData() {
      return get(userPath(request.auth.uid)).data;
    }

    function isAdmin() {
      return signedIn()
        && exists(userPath(request.auth.uid))
        && currentUserData().role == "admin";
    }

    function isPublished() {
      return resource.data.status == "published";
    }

    function validContentStatus() {
      return request.resource.data.status in ["draft", "published", "archived"];
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          "username",
          "email",
          "emoji",
          "role",
          "membership",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.role == "member"
        && request.resource.data.membership == "JAE HQ Member"
        && request.resource.data.email == request.auth.token.email;

      allow read: if isOwner(userId) || isAdmin();

      allow update: if (
          isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "username",
            "emoji",
            "updatedAt"
          ])
        )
        || isAdmin();

      allow delete: if isAdmin() && request.auth.uid != userId;
    }

    match /posts/{postId} {
      allow read: if isPublished() || isAdmin();
      allow create, update: if isAdmin()
        && validContentStatus()
        && request.resource.data.title is string
        && request.resource.data.slug is string;
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isPublished() || isAdmin();
      allow create, update: if isAdmin()
        && validContentStatus()
        && request.resource.data.name is string
        && request.resource.data.slug is string;
      allow delete: if isAdmin();
    }

    match /youtube/{entryId} {
      allow read: if isPublished() || isAdmin();
      allow create, update: if isAdmin()
        && validContentStatus()
        && request.resource.data.title is string;
      allow delete: if isAdmin();
    }

    match /books/{bookId} {
      allow read: if isPublished() || isAdmin();
      allow create, update: if isAdmin()
        && validContentStatus()
        && request.resource.data.title is string;
      allow delete: if isAdmin();
    }

    match /travel/{entryId} {
      allow read: if isPublished() || isAdmin();
      allow create, update: if isAdmin()
        && validContentStatus()
        && request.resource.data.title is string;
      allow delete: if isAdmin();
    }

    // Phase 4 will open member comment creation with strict validation.
    // Until then, Admin Studio can read and moderate migrated/future comments.
    match /comments/{commentId} {
      allow read, delete: if isAdmin();
      allow create, update: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
